{
  "name": "xtreme-bookmarks",
  "version": "2.0.0",
  "description": "Xtreme Bookmarks — 2nd Brain knowledge engine. Sync X/Twitter bookmarks, build a wiki, run maintenance agents, and manage tiered memory.",
  "type": "module",
  "bin": {
    "ftb": "bin/ft.mjs",
    "xb": "bin/ft.mjs",
    "xtreme-bookmarks": "bin/ft.mjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "tsx --test tests/**/*.test.ts",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "bin/",
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MGerardLoveable/xtreme-bookmarks.git"
  },
  "keywords": [
    "bookmarks",
    "twitter",
    "x",
    "second-brain",
    "knowledge-base",
    "wiki",
    "memory-tiers",
    "search",
    "fts5",
    "sqlite",
    "local-first",
    "agents",
    "cli"
  ],
  "dependencies": {
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "sql.js": "^1.14.1",
    "sql.js-fts5": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/sql.js": "^1.4.11",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
