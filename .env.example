# Xtreme Bookmarks environment template.
# Copy this file to .env.local for local use or configure these values
# as secure environment variables on your server.

# Optional: higher X API limits / filtered stream mode.
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
X_CALLBACK_URL=http://localhost:3847/auth/callback

# Optional: xAI / Grok helper model.
XAI_API_KEY=
XAI_MODEL=

# Optional: web search for Brain Research Scout.
BRAVE_SEARCH_API_KEY=

# Optional: override where bookmark data is stored.
# Do not point this inside the Git repo.
XTREME_BOOKMARKS_DATA_DIR=
XTREME_BOOKMARKS_WEB_USER=xtreme
XTREME_BOOKMARKS_WEB_PASSWORD=
